model Payment {
    id String @id @default(uuid())

    // Relations (Foreign Keys)

    rental_request_id String

    // Payment Details
    amount         Int
    currency       String        @db.VarChar(10)
    status         PaymentStatus @default(PENDING)
    payment_method String

    stripe_payment_intent_id   String  @unique @db.VarChar(255)
    stripe_checkout_session_id String? @db.VarChar(255)

    // Metadata / Logs
    receipt_url    String? @db.Text
    failure_reason String? @db.Text

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relation 

    rental_request Rental @relation(fields: [rental_request_id], references: [id])

    @@map("payments")
}
