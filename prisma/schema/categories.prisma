model Category {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  properties  Property[]

  @@map("categories")
}
