model User {
    id       String @id @default(uuid())
    name     String @db.VarChar(255)
    email    String @unique
    password String

    role       Role       @default(TENANT)
    status     status     @default(ACTIVE)
    profile    Profile?
    properties Property[]
    rental     Rental[]
    createdAt  DateTime   @default(now())
    updatedAt  DateTime   @updatedAt

    @@map("users")
}
