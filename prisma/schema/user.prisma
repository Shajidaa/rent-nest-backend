model User {
    id       String @id @default(uuid())
    name     String @db.VarChar(255)
    email    String @unique
    password String

    role      Role     @default(TENANT)
    status    status   @default(ACTIVE)
    profile   Profile?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
