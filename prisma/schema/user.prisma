model User {
  id         String     @id @default(uuid())
  name       String     @db.VarChar(255)
  email      String     @unique
  password   String
  role       Role       @default(TENANT)
  status     status     @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
  profile    Profile?
  rental     Rental[]

  @@map("users")
}
